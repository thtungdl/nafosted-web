# ====== Sao chép thành .env.local (khi chạy máy) và đặt trong Vercel → Settings → Environment Variables ======

# --- NextAuth (đăng nhập Google) ---
NEXTAUTH_URL=https://<ten-app>.vercel.app
NEXTAUTH_SECRET=            # tạo bằng: openssl rand -base64 32

# --- OAuth Google (dùng chung cho đăng nhập thành viên + ghi Drive) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Phân quyền ---
# Danh sách email được phép nộp (phân tách bằng dấu phẩy)
ALLOWED_EMAILS=thtungdl@gmail.com,khanhlinh@phenikaa-uni.edu.vn,khanhmai@phenikaa-uni.edu.vn
# Email được quyền duyệt/gộp tiến độ (admin)
ADMIN_EMAILS=thtungdl@gmail.com

# --- Ghi Google Drive dưới TÀI KHOẢN CỦA ANH (lấy 1 lần, xem README) ---
DRIVE_REFRESH_TOKEN=

# ID thư mục "4. Nafosted/Project management system" (chứa dashboard + sidecar dữ liệu)
# — nơi ghi nafosted-*.json/.js để đồng bộ. Các loại dữ liệu đồng bộ: cong / giaoviec / sop.
# (2026-07-02: dời từ gốc 4. Nafosted sang Project management system/ — xem dashboard-tien-do.md)
NAFOSTED_FOLDER_ID=